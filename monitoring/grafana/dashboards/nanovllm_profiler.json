{
  "title": "nano-vLLM Profiler",
  "uid": "nanovllm-profiler",
  "schemaVersion": 39,
  "version": 7,
  "editable": true,
  "timezone": "browser",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "run_tag",
        "label": "run_tag",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(nanovllm_request_ttft_milliseconds, run_tag)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": ["transformers(title+query)", "nanovllm(title+query)"],
          "value": ["transformers(title+query)", "nanovllm(title+query)"]
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "TTFT by request order, per run_tag",
      "description": "run 전체를 percentile 하나로 뭉개지 않고, 요청이 도착한 순서(request_index)대로 TTFT가 어떻게 변하는지 그대로 보여준다. X축 = 요청 순서, 색상별 선 = run_tag.",
      "type": "trend",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "options": {
        "xField": "request_index",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "always",
            "pointSize": 6
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "request_index"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nanovllm_request_ttft_milliseconds{run_tag=~\"$run_tag\"}",
          "instant": true,
          "range": false,
          "format": "time_series",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "request_index",
                "destinationType": "number"
              }
            ],
            "fields": {}
          }
        },
        {
          "id": "partitionByValues",
          "options": {
            "fields": [
              "run_tag"
            ],
            "keepFields": false,
            "naming": {
              "asLabels": true
            }
          }
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "request_index",
            "mode": "outer"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^\\S+\\s+(.*)$",
            "renamePattern": "$1"
          }
        }
      ]
    },
