    {
      "id": 3,
      "title": "Aggregate Throughput (tok/s) by run_tag",
      "description": "run 전체를 요약한 스칼라 1개(집계 처리량)라 막대 비교가 자연스럽다.",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
